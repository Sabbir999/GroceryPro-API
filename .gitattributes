# Auto detect text files and normalize to LF
* text=auto eol=lf

# Shell scripts must always use LF
*.sh text eol=lf

# Python files use LF
*.py text eol=lf

# Docker files use LF
Dockerfile text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Windows batch files use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
 